# ----------------------------------------------------------------------------
# U-QaaS local configuration. Copy to `.env` and fill in only what you need.
# This is a LOCAL, single-researcher tool: there is NO authentication.
# Never commit your real .env (it is gitignored).
# ----------------------------------------------------------------------------

APP_ENV=development
DATABASE_URL=sqlite:///./quantum_jobs.db
RESULTS_DIR=./job_results
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Async execution -------------------------------------------------------
# Full async stack (docker compose) uses Redis + a Celery worker:
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
WORKER_METRICS_PORT=9100
# For a quick local run WITHOUT Redis/worker, set this to true and jobs execute
# synchronously in the API process:
CELERY_TASK_ALWAYS_EAGER=false

# --- IBM Quantum (free tier available) -------------------------------------
ENABLE_IBM=false
IBM_QUANTUM_TOKEN=
# New IBM Quantum Platform uses a CRN as the instance; channel defaults to
# ibm_quantum_platform. For the legacy platform use channel=ibm_quantum.
IBM_INSTANCE=
IBM_CHANNEL=ibm_quantum_platform

# --- AWS Braket (paid per shot) --------------------------------------------
ENABLE_AWS_BRAKET=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Braket writes results to S3; the bucket must exist and be writable.
AWS_BRAKET_S3_BUCKET=
AWS_BRAKET_S3_PREFIX=quantum-orchestrator

# --- Azure Quantum (paid) --------------------------------------------------
ENABLE_AZURE_QUANTUM=false
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_WORKSPACE_NAME=
AZURE_LOCATION=
# Optional service principal (otherwise the default Azure credential chain is used)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
