{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "U-QaaS Orchestration",
  "tags": ["qaas", "quantum"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Jobs Submitted (total)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(qaas_jobs_submitted_total)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } }
    },
    {
      "type": "stat",
      "title": "Jobs Finished by Status",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum by (status) (qaas_jobs_finished_total)", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Backend Runs by Provider",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 0 },
      "targets": [
        { "expr": "sum by (provider) (qaas_backend_runs_total)", "legendFormat": "{{provider}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Job Submission Rate (per strategy)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum by (strategy) (rate(qaas_jobs_submitted_total[5m]))", "legendFormat": "{{strategy}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend Runs Rate (provider/status)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum by (provider, status) (rate(qaas_backend_runs_total[5m]))", "legendFormat": "{{provider}} / {{status}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backend Execution Time p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(qaas_backend_execution_seconds_bucket[5m])))", "legendFormat": "{{provider}} p95", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "sum by (handler) (rate(http_requests_total[5m]))", "legendFormat": "{{handler}}", "refId": "A" }
      ]
    }
  ]
}
